  <Product Id="35CE40BF-2F47-409E-BA49-4757F6A3F1DA" Name="!(loc.ApplicationName)" Language="!(loc.Language)" Version="1.1.2.12" Manufacturer="!(loc.ManufacturerFullName)" UpgradeCode="$(var.UpgradeCode)">
    <Package Id="30EE239D-F5EA-4630-90CB-22AE1F31DCC4" InstallerVersion="200" Compressed="yes" InstallScope="perMachine" Description="!(loc.ProductDescription)"/>

    <!--<WixVariable Id="WixUILicenseRtf" Value="!(loc.LicenseRtf)" />-->

    <!-- UI customization -->
    <WixVariable Id="WixUIBannerBmp" Value="Dialog.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="Dialog.bmp" />

    <!-- Define icons (ID should not be longer than 18 chars and must end with ".exe") -->
    <Icon Id="Icon.exe" SourceFile="wpf.ico" />

    <!-- Set properties for add/remove programs -->
    <Property Id="ARPPRODUCTICON" Value="Icon.exe" />
    <Property Id="ARPHELPLINK" Value="$(var.InfoURL)" />
    <Property Id="APPNOREPAIR" Value="yes" Secure="yes" />
    <!-- Remove repair -->
    <!--<Property Id="APPNOMODIFY" Value="yes" Secure="yes" />-->
    <!-- Remove modify -->

    <netfx:DotNetCompatibilityCheck
      Property="DOTNETRUNTIMECHECK"
      RollForward="major"
      RuntimeType="desktop"
      Platform="x64"
      Version="6.0.0"/>
      
    <Property Id="WIX_IS_NET8_DESKTOP_INSTALLED">
      <!-- Search for the presence of the .NET 8.0 key in the InstalledVersions registry path -->
      <RegistrySearch
          Id="Net8DesktopRuntimeSearch"
          Root="HKLM"
          Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedfx\Microsoft.WindowsDesktop.App"
          Name="8.0"
          Type="raw" />
    </Property>

    <Media Id="1" Cabinet="product.cab" EmbedCab="yes"/>

    <PropertyRef Id="WIX_IS_NET8_DESKTOP_INSTALLED"/>
    <PropertyRef Id="DOTNETRUNTIMECHECK"/>
    <Condition Message="!(loc.RequiresDotNetCore8)">
      <![CDATA[Installed OR DOTNETRUNTIMECHECK]]>
    </Condition>

